// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model Usuario {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  nombre          String
  apellido        String    @default("")
  password        String
  rol             Rol       @default(OPERADOR)
  plan            PlanTipo  @default(FREE)
  planExpira      DateTime?
  mpSuscripcionId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  resetToken       String?
  resetTokenExpiry DateTime?

  emailVerificado Boolean @default(false)
  emailVerifToken String?

  trialUsado Boolean @default(false)

  campos      Campo[]
  animales    Animal[]
  tareas      TareaRural[]
  movimientos MovimientoFinanciero[]
  campanias   Campania[]
  maquinarias Maquinaria[]

  organizacionesQueEsDueno Organizacion[]           @relation("organizacion_owner")
  membresiasOrganizacion   UsuarioOrganizacion[]
  invitaciones             InvitacionOrganizacion[]
  auditoriasLogs           AuditoriaLog[]           @relation("auditoriaLogs")
}

enum Rol {
  ADMIN
  OPERADOR
}

enum PlanTipo {
  FREE
  PRO
}

// ─── MÓDULO 1: GESTIÓN DE CULTIVOS ────────────────────────────────────────────

model Campo {
  id             Int      @id @default(autoincrement())
  nombre         String
  hectareas      Float
  ubicacion      String?
  propietario    String?
  latitud        Float?
  longitud       Float?
  usuarioId      Int
  organizacionId Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuario      Usuario                @relation(fields: [usuarioId], references: [id])
  organizacion Organizacion?          @relation(fields: [organizacionId], references: [id], onDelete: SetNull)
  lotes        Lote[]
  tareas       TareaRural[]
  movimentos   MovimientoFinanciero[]
  maquinarias  Maquinaria[]

  @@index([organizacionId])
}

model Lote {
  id        Int      @id @default(autoincrement())
  nombre    String
  hectareas Float
  campoId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campo    Campo     @relation(fields: [campoId], references: [id])
  siembras Siembra[]
}

model TipoCultivo {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  createdAt   DateTime @default(now())

  siembras Siembra[]
}

model Siembra {
  id            Int           @id @default(autoincrement())
  loteId        Int
  tipoCultivoId Int
  fechaSiembra  DateTime
  densidad      Float?
  observaciones String?
  estado        EstadoSiembra @default(EN_CURSO)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lote         Lote                   @relation(fields: [loteId], references: [id])
  tipoCultivo  TipoCultivo            @relation(fields: [tipoCultivoId], references: [id])
  cosechas     Cosecha[]
  aplicaciones AplicacionInsumo[]
  movimentos   MovimientoFinanciero[]
  campania     Campania?              @relation(fields: [campaniaId], references: [id])
  campaniaId   Int?
}

enum EstadoSiembra {
  EN_CURSO
  COSECHADA
  PERDIDA
}

model Cosecha {
  id              Int      @id @default(autoincrement())
  siembraId       Int
  fechaCosecha    DateTime
  rendimientoKgHa Float
  totalKg         Float
  humedad         Float?
  observaciones   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  siembra Siembra @relation(fields: [siembraId], references: [id])
}

model Insumo {
  id          Int        @id @default(autoincrement())
  nombre      String
  tipo        TipoInsumo
  unidad      String
  descripcion String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  aplicaciones AplicacionInsumo[]
}

enum TipoInsumo {
  FERTILIZANTE
  HERBICIDA
  FUNGICIDA
  INSECTICIDA
  SEMILLA
  OTRO
}

model AplicacionInsumo {
  id            Int      @id @default(autoincrement())
  siembraId     Int
  insumoId      Int
  fecha         DateTime
  cantidad      Float
  unidad        String
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  siembra Siembra @relation(fields: [siembraId], references: [id])
  insumo  Insumo  @relation(fields: [insumoId], references: [id])
}

// ─── MÓDULO 2: GANADERÍA ──────────────────────────────────────────────────────

model Animal {
  id              Int             @id @default(autoincrement())
  usuarioId       Int
  organizacionId  Int?
  nombre          String
  especie         Especie
  sexo            Sexo
  categoria       CategoriaAnimal
  peso            Float?
  fechaNacimiento DateTime?
  observaciones   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  usuario      Usuario        @relation(fields: [usuarioId], references: [id])
  organizacion Organizacion?  @relation(fields: [organizacionId], references: [id], onDelete: SetNull)
  preneces     Prenez[]
  pesos        RegistroPeso[]

  @@index([organizacionId])
}

model Prenez {
  id                 Int          @id @default(autoincrement())
  animalId           Int
  fechaInicio        DateTime
  fechaEstimadaParto DateTime
  estado             EstadoPrenez @default(EN_CURSO)
  observaciones      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

enum Especie {
  BOVINO
  PORCINO
  EQUINO
  OVINO
  CAPRINO
  AVIAR
}

enum Sexo {
  MACHO
  HEMBRA
}

enum CategoriaAnimal {
  // Bovino
  VACA
  VAQUILLONA
  TERNERA
  TORO
  NOVILLO
  TERNERO
  // Porcino
  CERDA
  VERRACO
  LECHON
  // Equino
  YEGUA
  POTRANCA
  PADRILLO
  POTRO
  // Ovino
  OVEJA
  BORREGA
  CARNERO
  CORDERO
  // Caprino
  CABRA
  CABRIO
  CABRITO
  // Aviar
  GALLINA
  GALLO
  POLLO
  POLLA
}

enum EstadoPrenez {
  EN_CURSO
  COMPLETADA
  PERDIDA
}

// ─── MÓDULO 3: TAREAS RURALES ─────────────────────────────────────────────────

model TareaRural {
  id              Int          @id @default(autoincrement())
  usuarioId       Int
  organizacionId  Int?
  titulo          String
  descripcion     String?
  tipo            TipoTarea
  estado          EstadoTarea  @default(PENDIENTE)
  prioridad       Prioridad    @default(MEDIA)
  fechaProgramada DateTime
  fechaLimite     DateTime?
  fechaCompletada DateTime?
  repetir         RepetirTarea @default(UNICA)
  campoId         Int?
  observaciones   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: SetNull)
  campo        Campo?        @relation(fields: [campoId], references: [id])

  @@index([organizacionId])
}

enum TipoTarea {
  SIEMBRA
  COSECHA
  FUMIGACION
  FERTILIZACION
  RIEGO
  MANTENIMIENTO
  VETERINARIA
  OTRO
}

enum EstadoTarea {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  CANCELADA
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum RepetirTarea {
  UNICA
  SEMANAL
  QUINCENAL
  MENSUAL
}

// ─── MÓDULO 5: MAQUINARIAS ────────────────────────────────────────────────────

model Maquinaria {
  id                Int              @id @default(autoincrement())
  usuarioId         Int
  organizacionId    Int?
  campoId           Int?
  nombre            String
  tipo              TipoMaquinaria
  marca             String?
  modelo            String?
  anio              Int?
  patente           String?
  estado            EstadoMaquinaria @default(OPERATIVA)
  horasUso          Float?
  seguroVencimiento DateTime?
  vtvVencimiento    DateTime?
  observaciones     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  usuario        Usuario                   @relation(fields: [usuarioId], references: [id])
  organizacion   Organizacion?             @relation(fields: [organizacionId], references: [id], onDelete: SetNull)
  campo          Campo?                    @relation(fields: [campoId], references: [id])
  mantenimientos MantenimientoMaquinaria[]
  gastos         GastoMaquinaria[]

  @@index([organizacionId])
}

model MantenimientoMaquinaria {
  id                   Int               @id @default(autoincrement())
  maquinariaId         Int
  tipo                 TipoMantenimiento
  descripcion          String?
  fecha                DateTime
  horasUso             Float?
  costo                Float?
  proximoMantenimiento DateTime?
  observaciones        String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  maquinaria Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)
}

model GastoMaquinaria {
  id            Int          @id @default(autoincrement())
  maquinariaId  Int
  tipo          TipoGastoMaq
  descripcion   String
  monto         Float
  fecha         DateTime
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  maquinaria Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)
}

enum TipoMaquinaria {
  TRACTOR
  SEMBRADORA
  PULVERIZADORA
  COSECHADORA
  CAMIONETA
  MIXER
  ACOPLADO
  TOLVA
  HERRAMIENTA
  OTRO
}

enum EstadoMaquinaria {
  OPERATIVA
  EN_MANTENIMIENTO
  FUERA_DE_SERVICIO
}

enum TipoMantenimiento {
  CAMBIO_ACEITE
  REVISION_GENERAL
  REPARACION
  OTRO
}

enum TipoGastoMaq {
  COMBUSTIBLE
  REPARACION
  REPUESTO
  SERVICIO
  SEGURO
  OTRO
}

// ─── MÓDULO 4: FINANZAS ───────────────────────────────────────────────────────

model MovimientoFinanciero {
  id             Int                 @id @default(autoincrement())
  usuarioId      Int
  organizacionId Int?
  tipo           TipoMovimiento
  concepto       String
  monto          Float
  fecha          DateTime
  categoria      CategoriaMovimiento
  campoId        Int?
  siembraId      Int?
  observaciones  String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: SetNull)
  campo        Campo?        @relation(fields: [campoId], references: [id])
  siembra      Siembra?      @relation(fields: [siembraId], references: [id])

  @@index([organizacionId])
}

enum TipoMovimiento {
  INGRESO
  EGRESO
}

enum CategoriaMovimiento {
  COSECHA
  VENTA_ANIMAL
  INSUMO
  SERVICIO
  MANTENIMIENTO
  VETERINARIA
  COMBUSTIBLE
  MANO_DE_OBRA
  OTRO
}

// ─── MÓDULO 5: CAMPAÑAS AGRÍCOLAS ─────────────────────────────────────────────

model Campania {
  id             Int       @id @default(autoincrement())
  usuarioId      Int
  organizacionId Int?
  nombre         String
  fechaInicio    DateTime
  fechaFin       DateTime?
  descripcion    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  organizacion Organizacion? @relation(fields: [organizacionId], references: [id], onDelete: SetNull)
  siembras     Siembra[]

  @@index([organizacionId])
}

// ─── MÓDULO 6: HISTORIAL DE PESOS ─────────────────────────────────────────────

model RegistroPeso {
  id            Int      @id @default(autoincrement())
  animalId      Int
  peso          Float
  fecha         DateTime
  observaciones String?
  createdAt     DateTime @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)
}

// ─── MULTIORG: ORGANIZACIONES ──────────────────────────────────────────────────

model Organizacion {
  id            Int      @id @default(autoincrement())
  nombre        String
  email         String   @unique
  plan          PlanTipo @default(FREE)
  propietarioId Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  propietario          Usuario                  @relation("organizacion_owner", fields: [propietarioId], references: [id])
  miembros             UsuarioOrganizacion[]
  campos               Campo[]
  animales             Animal[]
  maquinarias          Maquinaria[]
  tareas               TareaRural[]
  movimientos          MovimientoFinanciero[]
  campanias            Campania[]
  invitaciones         InvitacionOrganizacion[]
  asignacionesRecursos AsignacionRecurso[]
  rolesPersonalizados  RolPersonalizado[]
  auditoriasLogs       AuditoriaLog[]           @relation("auditoriaLogs")

  @@index([propietarioId])
}

model UsuarioOrganizacion {
  id             Int                 @id @default(autoincrement())
  usuarioId      Int
  organizacionId Int
  rol            RolOrganizacion     @default(OPERARIO)
  estado         EstadoMiembro       @default(ACTIVO)
  asignaciones   AsignacionRecurso[]
  asignacionesPermiso AsignacionPermiso[] @relation("asignacionesPermiso")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  organizacion Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, organizacionId])
  @@index([usuarioId])
  @@index([organizacionId])
  @@index([rol])
}

model AsignacionRecurso {
  id                    Int         @id @default(autoincrement())
  usuarioOrganizacionId Int
  organizacionId        Int
  recursoTipo           TipoRecurso
  recursoId             Int
  permisosTipo          String? // JSON: {"ver": true, "editar": false}
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  usuarioOrganizacion UsuarioOrganizacion @relation(fields: [usuarioOrganizacionId], references: [id], onDelete: Cascade)
  Organizacion        Organizacion        @relation(fields: [organizacionId], references: [id])

  @@unique([usuarioOrganizacionId, recursoTipo, recursoId])
  @@index([usuarioOrganizacionId])
  @@index([organizacionId, recursoTipo, recursoId])
}

model InvitacionOrganizacion {
  id             Int              @id @default(autoincrement())
  organizacionId Int
  email          String
  rol            RolOrganizacion  @default(OPERARIO)
  token          String           @unique
  estado         EstadoInvitacion @default(PENDIENTE)
  expiresAt      DateTime
  aceptadoEn     DateTime?
  usuarioId      Int?
  createdAt      DateTime         @default(now())

  organizacion Organizacion @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  usuario      Usuario?     @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([token])
  @@index([organizacionId])
}

// ─── ENUMS: MULTIORG ───────────────────────────────────────────────────────────

enum RolOrganizacion {
  OWNER
  ADMIN
  OPERARIO
  CONTADOR
  ASESOR
  CONTRATISTA
}

enum TipoRecurso {
  ORGANIZACION
  CAMPO
  LOTE
  MAQUINARIA
  ANIMAL
  TAREA
  MODULO
}

enum EstadoMiembro {
  ACTIVO
  INVITADO
  INACTIVO
  SUSPENDIDO
}

enum EstadoInvitacion {
  PENDIENTE
  ACEPTADA
  RECHAZADA
  EXPIRADA
}

// ─── ROLES Y PERMISOS AVANZADOS ────────────────────────────────────────────────

model RolPersonalizado {
  id             Int      @id @default(autoincrement())
  organizacionId Int
  nombre         String   // ASESOR, CONTRATISTA, etc.
  descripcion    String?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizacion   Organizacion       @relation(fields: [organizacionId], references: [id], onDelete: Cascade)
  asignaciones   AsignacionPermiso[]

  @@unique([organizacionId, nombre])
  @@index([organizacionId])
}

model AsignacionPermiso {
  id                    Int      @id @default(autoincrement())
  usuarioOrganizacionId Int
  rolPersonalizadoId    Int
  recursoTipo           String?  // "CAMPO", "TAREA", null = acceso general
  recursoId             Int?     // ID específico del recurso
  fechaInicio           DateTime
  fechaVencimiento      DateTime
  activo                Boolean  @default(true)
  notas                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  usuarioOrganizacion UsuarioOrganizacion @relation("asignacionesPermiso", fields: [usuarioOrganizacionId], references: [id], onDelete: Cascade)
  rolPersonalizado    RolPersonalizado    @relation(fields: [rolPersonalizadoId], references: [id], onDelete: Cascade)

  @@index([usuarioOrganizacionId])
  @@index([rolPersonalizadoId])
  @@index([fechaVencimiento])
}

model AuditoriaLog {
  id             Int      @id @default(autoincrement())
  usuarioId      Int
  organizacionId Int?
  accion         String   // "login", "crear_campo", "modificar_tarea", etc.
  entidad        String?  // "Campo", "Tarea", "Maquinaria"
  entidadId      Int?
  cambios        String?  // JSON con detalles del cambio
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  usuario      Usuario        @relation("auditoriaLogs", fields: [usuarioId], references: [id], onDelete: Cascade)
  organizacion Organizacion?  @relation("auditoriaLogs", fields: [organizacionId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([organizacionId])
  @@index([createdAt])
  @@index([accion])
}
