# ─── Base de datos (Neon / Railway PostgreSQL) ──────────────────────────────
# Neon: obtené la URL en https://console.neon.tech → Settings → Connection string
# Railway: se inyecta automáticamente como ${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://postgres:password@localhost:5432/agromanager"

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generá un valor seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia_este_valor_en_produccion"

# ─── Puerto (Railway lo inyecta, no es necesario setearlo a mano) ──────────
PORT=3001

# ─── CORS: URL del frontend desplegado (Vercel) ────────────────────────────
# Separá con comas si querés múltiples orígenes:
# FRONTEND_URL=https://agromanager.vercel.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173
